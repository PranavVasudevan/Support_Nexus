# ═══════════════════════════════════════════════════════════════
#  TicketAI v2 — Environment Variables (LOCAL / no-Docker mode)
#  These values run the app with zero external services.
#  docker-compose overrides POSTGRES_URL / MONGO_URL / REDIS_URL / MLFLOW_URI
#  with its own container hostnames, so this file is safe for both modes.
# ═══════════════════════════════════════════════════════════════

# ── LLM (LOCAL — Ollama, fully offline) ─────────────────────────
# Runs against a local Ollama server. No API key, no rate limits, no cloud.
#   Install:  https://ollama.com/download
#   Pull:     ollama pull qwen2.5:7b
# Used as the classifier when no DistilBERT model is trained yet, and as the
# fallback when DistilBERT confidence < DISTILBERT_FALLBACK_THRESHOLD.
# qwen2.5:3b fits entirely in the RTX 3050's 4GB VRAM → ~64 tok/s (GPU).
# qwen2.5:7b only partially fits (45% GPU / 55% CPU) → ~4.5 tok/s. Switch the
# model below to qwen2.5:7b if you prefer its higher accuracy over speed.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_ENABLED=true

# ── DATABASES ────────────────────────────────────────────────────
# PostgreSQL (local server). The app auto-upgrades this to the asyncpg driver.
# To fall back to the zero-install SQLite file, use:
#   POSTGRES_URL=sqlite+aiosqlite:///./data/app.db
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/tickets_db
MONGO_URL=
REDIS_URL=

# ── MODEL ────────────────────────────────────────────────────────
MODEL_PATH=./models/distilbert_finetuned
BASE_MODEL=distilbert-base-uncased
# DistilBERT predictions below this confidence defer to the local LLM.
DISTILBERT_FALLBACK_THRESHOLD=0.70

# ── CONFIDENCE THRESHOLDS (routing) ──────────────────────────────
CONFIDENCE_AUTONOMOUS=0.95
CONFIDENCE_HITL=0.80

# ── SCALABILITY ──────────────────────────────────────────────────
MAX_CLASSIFY_CONCURRENCY=50
SESSION_TTL_SECONDS=3600

# ── RETRAINING ───────────────────────────────────────────────────
RETRAIN_MIN_SAMPLES=100
RETRAIN_SCHEDULE_HOUR=2
# Nightly auto-retrain scheduler (off for local runs).
ENABLE_SCHEDULER=false

# ── MLFLOW (optional — blank = disabled locally) ─────────────────
MLFLOW_URI=

# ── APP ──────────────────────────────────────────────────────────
ENVIRONMENT=development
