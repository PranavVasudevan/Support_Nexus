# ═══════════════════════════════════════════════════════════════
#  TicketAI v2 — Environment Variables  (copy to .env and edit)
#
#  Defaults below are for LOCAL / no-Docker mode (SQLite + in-memory).
#  For the Docker full stack, docker-compose injects its own container
#  hostnames; point OLLAMA_BASE_URL at the host (see docker-compose.yml).
# ═══════════════════════════════════════════════════════════════

# ── LLM (LOCAL — Ollama, fully offline) ─────────────────────────
# No API key needed. Install https://ollama.com then: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_ENABLED=true

# ── DATABASES ────────────────────────────────────────────────────
# LOCAL (no Docker):
POSTGRES_URL=sqlite+aiosqlite:///./data/app.db
MONGO_URL=
REDIS_URL=
# DOCKER full stack (uncomment, comment the three lines above):
# POSTGRES_URL=postgresql://ticketuser:ticketpass@postgres:5432/tickets_db
# MONGO_URL=mongodb://mongodb:27017/ticket_logs
# REDIS_URL=redis://redis:6379

# ── MODEL ────────────────────────────────────────────────────────
MODEL_PATH=./models/distilbert_finetuned
BASE_MODEL=distilbert-base-uncased
# DistilBERT predictions below this confidence defer to the local LLM.
DISTILBERT_FALLBACK_THRESHOLD=0.70

# ── CONFIDENCE THRESHOLDS (routing) ──────────────────────────────
CONFIDENCE_AUTONOMOUS=0.95
CONFIDENCE_HITL=0.80

# ── SCALABILITY ──────────────────────────────────────────────────
MAX_CLASSIFY_CONCURRENCY=50
SESSION_TTL_SECONDS=3600

# ── RETRAINING ───────────────────────────────────────────────────
RETRAIN_MIN_SAMPLES=100
RETRAIN_SCHEDULE_HOUR=2
ENABLE_SCHEDULER=false

# ── MLFLOW (optional — blank = disabled) ─────────────────────────
MLFLOW_URI=

# ── APP ──────────────────────────────────────────────────────────
ENVIRONMENT=development
